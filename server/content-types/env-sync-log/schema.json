{
  "kind": "collectionType",
  "collectionName": "env_sync_logs",
  "info": {
    "singularName": "env-sync-log",
    "pluralName": "env-sync-logs",
    "displayName": "Env Sync Log",
    "description": "Audit trail for every content sync operation triggered between environments"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": { "visible": false },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "triggeredBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user",
      "comment": "The admin user who triggered this sync"
    },
    "contentType": {
      "type": "string",
      "required": true,
      "comment": "Strapi UID, e.g. api::article.article"
    },
    "syncDocumentId": {
      "type": "string",
      "required": true,
      "comment": "The documentId of the synced Strapi document (renamed from documentId — reserved in v5)"
    },
    "locale": {
      "type": "string",
      "comment": "Locale being synced, null for non-i18n content"
    },
    "sourceEnv": {
      "type": "enumeration",
      "enum": ["SIT", "QA", "UAT", "PROD"],
      "required": true
    },
    "targetEnv": {
      "type": "enumeration",
      "enum": ["SIT", "QA", "UAT", "PROD"],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "in_progress", "success", "failed", "rolled_back", "dry_run"],
      "required": true,
      "default": "pending"
    },
    "conflictStrategy": {
      "type": "enumeration",
      "enum": ["source-wins", "target-wins", "manual"],
      "required": true,
      "default": "source-wins"
    },
    "isDryRun": {
      "type": "boolean",
      "default": false
    },
    "diffSummary": {
      "type": "json",
      "comment": "Structured diff: { fieldsChanged, relationsUpdated, mediaReuploaded, localesSynced }"
    },
    "payload": {
      "type": "json",
      "comment": "Truncated serialised document payload (for debugging)"
    },
    "errorMessage": {
      "type": "text"
    },
    "errorStack": {
      "type": "text",
      "comment": "Stack trace — only stored in non-production envs"
    },
    "snapshotId": {
      "type": "string",
      "comment": "documentId of the env-sync-snapshot entry for rollback"
    },
    "duration": {
      "type": "integer",
      "comment": "Total sync duration in milliseconds"
    },
    "retryCount": {
      "type": "integer",
      "default": 0
    },
    "triggeredAt": {
      "type": "datetime",
      "required": true
    },
    "completedAt": {
      "type": "datetime"
    },
    "targetUrl": {
      "type": "string"
    },
    "idempotencyKey": {
      "type": "string"
    }
  }
}
